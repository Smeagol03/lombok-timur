# Application Settings
APP_NAME="Portal Lombok Timur"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Note: Set APP_ENV=production when deploying to shared hosting

# Localization
APP_LOCALE=id
APP_FALLBACK_LOCALE=id
APP_FAKER_LOCALE=id_ID
APP_TIMEZONE="Asia/Makassar"

# Maintenance
APP_MAINTENANCE_DRIVER=file

# Database - SQLite (Development)
DB_CONNECTION=sqlite

# Database - MySQL (Production)
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=lombok_timur
# DB_USERNAME=your_username
# DB_PASSWORD=your_password

# Session & Cache
SESSION_DRIVER=database
SESSION_LIFETIME=120
CACHE_STORE=database
QUEUE_CONNECTION=database

# Redis (Production - Optional)
# REDIS_CLIENT=phpredis
# REDIS_HOST=127.0.0.1
# REDIS_PASSWORD=null
# REDIS_PORT=6379

# Mail Configuration
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@lomboktimurkab.go.id"
MAIL_FROM_NAME="${APP_NAME}"

# File Storage
FILESYSTEM_DISK=public

# Media Library (Spatie)
MEDIA_DISK=public
# MEDIA_PATH=media

# Scout Search (Database Driver)
SCOUT_DRIVER=database
# SCOUT_QUEUE=true

# Filament Admin
FILAMENT_PATH=admin

# Security Headers (Production)
# Enable HSTS in production with HTTPS
# SESSION_SECURE_COOKIE=true

# Logging
LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug